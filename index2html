<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UiPath Automations | Robot</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Inter:wght@300;500&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        /* Reset & Variabile */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        :root {
            --bg-dark: #070b14;
            --accent-cyan: #00e6ff;
            --accent-orange: #ff6a00;
            --text-light: #e2e8f0;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
        }
        h1, h2, h3 {
            font-family: 'Orbitron', sans-serif;
        }

        /* --- ANIMAȚII --- */
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
            100% { transform: translateY(0px); }
        }
        @keyframes scan {
            0% { top: 0; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 100%; opacity: 0; }
        }
        @keyframes spin {
            100% { transform: rotate(360deg); }
        }
        @keyframes pulseGlow {
            0% { box-shadow: 0 0 10px rgba(0, 230, 255, 0.2); }
            50% { box-shadow: 0 0 30px rgba(0, 230, 255, 0.6); }
            100% { box-shadow: 0 0 10px rgba(0, 230, 255, 0.2); }
        }

        /* --- STRUCTURĂ --- */
        nav {
            display: flex;
            justify-content: space-between;
            padding: 20px 50px;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 100;
            background: rgba(7, 11, 20, 0.8);
            backdrop-filter: blur(10px);
        }
        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-cyan);
            letter-spacing: 2px;
        }

        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: space-around;
            padding: 0 10%;
            position: relative;
        }
        .hero-text {
            max-width: 500px;
            z-index: 2;
        }
        .hero-text h1 {
            font-size: 3.5rem;
            margin-bottom: 20px;
            background: -webkit-linear-gradient(45deg, var(--accent-cyan), var(--accent-orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .btn {
            display: inline-block;
            padding: 12px 30px;
            margin-top: 20px;
            background: transparent;
            color: var(--accent-cyan);
            border: 1px solid var(--accent-cyan);
            border-radius: 4px;
            text-transform: uppercase;
            font-family: 'Orbitron', sans-serif;
            text-decoration: none;
            transition: all 0.3s ease;
            animation: pulseGlow 2s infinite;
        }
        .btn:hover {
            background: var(--accent-cyan);
            color: var(--bg-dark);
            box-shadow: 0 0 20px var(--accent-cyan);
        }

        .robot-container {
            position: relative;
            width: 300px;
            height: 300px;
            animation: float 4s ease-in-out infinite;
        }
        .robot-svg {
            width: 100%;
            height: 100%;
            filter: drop-shadow(0 0 15px rgba(0, 230, 255, 0.5));
        }
        .scanner-line {
            position: absolute;
            width: 100%;
            height: 2px;
            background: var(--accent-orange);
            box-shadow: 0 0 10px var(--accent-orange);
            animation: scan 3s linear infinite;
        }

        .processes {
            padding: 100px 10%;
            text-align: center;
        }
        .processes h2 {
            font-size: 2.5rem;
            margin-bottom: 50px;
        }
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        .card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(0, 230, 255, 0.1);
            padding: 40px 20px;
            border-radius: 10px;
            transition: transform 0.3s ease, border 0.3s ease;
        }
        .card:hover {
            transform: translateY(-10px);
            border-color: var(--accent-orange);
        }
        .gear-icon {
            width: 50px;
            height: 50px;
            margin-bottom: 20px;
            fill: var(--accent-cyan);
            animation: spin 6s linear infinite;
        }
        
        footer {
            text-align: center;
            padding: 30px;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: 50px;
            font-size: 0.9rem;
            opacity: 0.5;
        }

        @media (max-width: 768px) {
            .hero { flex-direction: column; text-align: center; justify-content: center; gap: 50px; }
            .hero-text h1 { font-size: 2.5rem; }
            nav { justify-content: center; }
        }
    </style>
</head>
